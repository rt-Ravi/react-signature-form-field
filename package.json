{
  "name": "react-signature-library",
  "version": "1.0.1",
  "description": "Lightweight and customizable React signature pad component",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "style": "dist/index.css",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "dependencies": {
    "signature_pad": "^5.1.3"
  },
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "signature",
    "signature pad",
    "canvas",
    "react signature",
    "form signature",
    "signature component"
  ],
  "author": "Ravi Thakur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rt-Ravi/react-signature-form-field"
  }
}
